// disk-recover - Disk Data Recovery Tool

#include "resource.h"

#define APSTUDIO_READONLY_SYMBOLS
#include "windows.h"
#undef APSTUDIO_READONLY_SYMBOLS

#if !defined(AFX_RESOURCE_DLL) || defined(AFX_TARG_ENU)
LANGUAGE LANG_ENGLISH, SUBLANG_ENGLISH_US
#pragma code_page(1252)

/////////////////////////////////////////////////////////////////////////////
// Menu

IDR_MAINFRAME MENU
BEGIN
    POPUP "&File"
    BEGIN
        MENUITEM "&Scan Disk",              IDM_SCAN
        MENUITEM "&Recover Files",          IDM_RECOVER
        MENUITEM SEPARATOR
        MENUITEM "Load &Demo Data",         IDM_DEMO_DATA
        MENUITEM SEPARATOR
        MENUITEM "E&xit",                   IDM_EXIT
    END
    POPUP "&Help"
    BEGIN
        MENUITEM "&About",                  IDM_ABOUT
    END
END

/////////////////////////////////////////////////////////////////////////////
// Accelerator

IDR_MAINFRAME ACCELERATORS
BEGIN
    "S",            IDM_SCAN,           VIRTKEY, CONTROL, NOINVERT
    "R",            IDM_RECOVER,        VIRTKEY, CONTROL, NOINVERT
    VK_ESCAPE,      IDM_STOP,           VIRTKEY, NOINVERT
END

/////////////////////////////////////////////////////////////////////////////
// String Table

STRINGTABLE
BEGIN
    IDR_MAINFRAME           "Disk Recover - Data Recovery Tool"
    IDM_SCAN                "Scan selected disk for recoverable files"
    IDM_RECOVER             "Recover selected files"
    IDM_EXIT                "Exit the application"
    IDM_ABOUT               "About Disk Recover"
    IDM_STOP                "Stop current operation"
END

#endif    // English (U.S.) resources

#ifndef APSTUDIO_INVOKED
/////////////////////////////////////////////////////////////////////////////
#endif    // not APSTUDIO_INVOKED